@using FirstMVCWebApp.Dto
@model UserDto

@if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show position-fixed"
         role="alert"
         style="top:20px; right:20px; width:350px; z-index:1050;">
        <strong>
            <i class="bi bi-exclamation-triangle-fill"></i>
            Error!
        </strong>
        @ViewBag.ErrorMessage

        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration Page</title>

    @* <!-- Bootstrap CSS --> *@
    @* <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"> *@
</head>
<body>

    <form asp-action="CreateUser">
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-5">
                    <div class="card shadow">
                        <div class="card-header text-center">
                            <h3>Registration Form</h3>
                        </div>

                        <div class="card-body">

                            <div class="mb-3">
                                <label for="username" class="form-label">
                                    Username
                                </label>
                                <input
                                    type="text"
                                    class="form-control"
                                    id="username"
                                    name="username"
                                    asp-for="Username"
                                    placeholder="Enter username"
                                    required>
                            </div>

                            <div class="mb-3">
                                <label for="email" class="form-label">
                                    Email Address
                                </label>
                                <input
                                    type="email"
                                    class="form-control"
                                    id="email"
                                    name="email"
                                    asp-for="Email"
                                    placeholder="Enter email"
                                    required>
                            </div>

                            <div class="mb-3">
                                <label for="password" class="form-label">
                                    Password
                                </label>
                                <input
                                    type="password"
                                    class="form-control"
                                    id="password"
                                    name="password"
                                    asp-for="Password"
                                    placeholder="Enter password"
                                    required>
                            </div>

                            <div class="d-flex gap-2">

                                @* <button type="submit" class="btn btn-success flex-fill">
                                    <i class="bi bi-person-check-fill"></i> Register
                                </button> *@
                                <input type="submit" class="btn btn-success flex-fill" value="Submit">
                                <button type="button"
                                        class="btn btn-secondary flex-fill"
                                        onclick="location.href='@Url.Action("Login","Auth")'">
                                    <i class="bi bi-arrow-left-circle"></i> Back
                                </button>

                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>

</body>
</html>