@using FirstMVCWebApp.Dto
@model ProductDto
@if (!string.IsNullOrEmpty(ViewBag.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show position-fixed"
         role="alert"
         style="top:20px; right:20px; width:350px; z-index:1050;">
        <strong>
            <i class="bi bi-check-circle-fill"></i>
            Success!
        </strong>
        @ViewBag.SuccessMessage

        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show position-fixed"
         role="alert"
         style="top:20px; right:20px; width:350px; z-index:1050;">
        <strong>
            <i class="bi bi-exclamation-triangle-fill"></i>
            Error!
        </strong>
        @ViewBag.ErrorMessage

        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>

    <div class="container mt-5">
        <div class="row justify-content-center">

            <div class="col-md-6">

                <div class="card shadow">
                    <div class="card-header @(Model?.Id>0? "bg-warning":"bg-success") text-white">
                        <h4 class="mb-0">
                            <i class="bi bi-plus-circle"></i>
                            @(Model?.Id>0 ? "Edit Product" : "Add Product")
                        </h4>
                    </div>

                    <div class="card-body">

                        @* <form asp-action="CreateProduct" method="post"> *@
                            <form asp-action="SaveProduct" method="post">
                                <input type="hidden" asp-for="Id"/>
                            <div class="mb-3">
                                <label asp-for="ProductName" class="form-label">
                                    Product Name <span class="text-danger">*</span>
                                </label>
                                <input asp-for="ProductName" class="form-control" name="productName" placeholder="Enetr Product Name" required />
                                <span asp-validation-for="ProductName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Description" class="form-label">
                                    Description <span class="text-danger">*</span>
                                </label>
                                <textarea name="description" asp-for="Description"
                                          class="form-control"
                                          rows="3" placeholder="Enetr Product Description"
                                          required></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Price" class="form-label">
                                    Price <span class="text-danger">*</span>
                                </label>
                                <input name="price" asp-for="Price"
                                       type="number"
                                       step="0.01"
                                       class="form-control" placeholder="Enetr Product Price"
                                       required />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label name="colour" asp-for="Colour" class="form-label">
                                    Colour <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Colour"
                                       class="form-control" placeholder="Enetr Product Colour"
                                       required />
                                <span asp-validation-for="Colour" class="text-danger"></span>
                            </div>

                            <div class="d-flex gap-2">

                                <button type="submit"
                                        class="btn btn-success flex-fill">
                                    <i class="bi bi-check-circle"></i>
                                    @(Model?.Id> 0 ? "Update Product" : "Save Product")
                                </button>

                                <a asp-controller="Dashboard"
                                   asp-action="Index"
                                   class="btn btn-secondary flex-fill">
                                    <i class="bi bi-arrow-left-circle"></i>
                                    Back
                                </a>

                            </div>

                        </form>

                    </div>
                </div>

            </div>

        </div>
    </div>

</body>
</html>